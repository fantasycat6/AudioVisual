# AudioVisual Web 配置文件
# 复制此文件为 .env 并修改配置

# ===== 基础配置 =====
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
PORT=5000

# ===== 数据库配置 =====
# 使用 SQLite（默认，无需额外配置）
DB_TYPE=sqlite
# SQLite 数据库路径（可选，默认在应用目录下）
# SQLITE_PATH=./audiovisual.db

# ===== MySQL 配置（如果 DB_TYPE=mysql 时需要填写） =====
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DB=audiovisual
