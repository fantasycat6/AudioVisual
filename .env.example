# AudioVisual Web - 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# 服务器配置
PORT=5000
NODE_ENV=development

# Session密钥（请修改为随机字符串）
SESSION_SECRET=your-secret-key-change-this-in-production

# 时区设置（默认上海）
TZ=Asia/Shanghai

# 管理员账户配置（可选，未配置时第一个注册用户自动成为管理员）
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# 数据库路径（可选）
# DB_PATH=./data/audiovisual.db
