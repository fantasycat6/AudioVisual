# AudioVisual Web 配置文件模板
# 复制此文件为 .env 并修改配置

# ===== 基础配置 =====
# 运行环境设置
# 可选值：development (开发), production (生产), testing (测试)
FLASK_ENV=production
FLASK_DEBUG=false

# Flask 应用密钥 (用于session等安全功能)
# 生成安全密钥: openssl rand -hex 32 或 python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_change_it

# 应用运行端口 (默认: 5000)
PORT=5000

# ===== 数据库配置 =====
# 数据库类型: sqlite (默认) 或 mysql
DB_TYPE=sqlite

# SQLite 数据库路径 (可选，默认在应用目录下)
# SQLITE_PATH=./audiovisual.db

# ===== MySQL 配置 (如果 DB_TYPE=mysql 时需要填写) =====
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DB=audiovisual

# ===== 视频解析接口配置 =====
# 解析接口相关配置可以在这里添加
# 例如: DEFAULT_API_TIMEOUT=10

# ===== 备份配置 =====
# 备份目录 (默认: ./backup/)
# BACKUP_DIR=./backup/

# ===== 应用时区配置 =====
# 设置应用时区，支持时区字符串或别名
# 时区字符串示例: Asia/Shanghai, UTC, America/New_York
# 时区别名: china, shanghai, beijing, utc, us_eastern, us_central, us_mountain, us_pacific
APP_TIMEZONE=Asia/Shanghai

# ===== 生产环境安全配置 =====
# 生产环境下必须配置安全密钥
# WTF CSRF 保护密钥（用于防止跨站请求伪造）
WTF_CSRF_SECRET_KEY=your_csrf_secret_key_here_change_it

# 生产环境数据库配置建议
# 建议使用MySQL进行生产部署，SQLite仅适用于开发环境

# ===== 生产环境日志配置 =====
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING
# 日志文件路径（为空则输出到控制台）
# LOG_FILE=./logs/audiovisual.log

# ===== 生产环境会话安全配置 =====
# 会话cookie安全设置（HTTPS环境推荐开启）
SESSION_COOKIE_SECURE=false  # 生产环境建议设置为true（如果启用HTTPS）
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ===== 管理员账户配置 =====
# 首次运行的默认管理员账户（如果设置，将在数据库初始化时创建）
# 如果不设置，第一个注册的用户将自动成为管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@example.com