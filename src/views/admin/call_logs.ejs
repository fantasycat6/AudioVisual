<%- include('../partials/header', { title: '调用记录管理', currentPage: 'admin' }) %>

<style>
    .main-container {
        max-width: 1400px;
        margin: 40px auto;
        padding: 0 20px;
    }
    
    .page-header {
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .page-header h1 {
        font-size: 28px;
        margin-bottom: 8px;
    }
    
    .page-header .subtitle {
        color: #999;
        font-size: 14px;
    }
    
    .stat-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }
    
    .stat-card {
        background-color: #252532;
        border-radius: 8px;
        padding: 16px;
    }
    
    .stat-value {
        font-size: 24px;
        font-weight: bold;
        color: #ff6768;
    }
    
    .stat-label {
        color: #999;
        font-size: 13px;
        margin-top: 4px;
    }
    
    .stat-note {
        color: #666;
        font-size: 12px;
        margin-top: 2px;
        font-style: italic;
    }
    
    /* 过滤器面板 */
    .filter-panel {
        background-color: #252532;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
    }
    
    .filter-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 16px;
        color: #fff;
    }
    
    .filter-row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }
    
    .filter-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 200px;
    }
    
    .filter-label {
        font-size: 12px;
        color: #999;
    }
    
    .filter-input, .filter-select {
        padding: 8px 12px;
        background-color: #1e1e2f;
        border: 1px solid #3a3a4a;
        border-radius: 6px;
        color: #fff;
        font-size: 14px;
    }
    
    .filter-input:focus, .filter-select:focus {
        outline: none;
        border-color: #ff6768;
    }
    
    .filter-actions {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }
    
    /* 日志表格 */
    .logs-table-wrapper {
        background-color: #252532;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 24px;
    }
    
    .logs-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .logs-table th {
        background-color: #2a2a3a;
        color: #999;
        font-weight: 500;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 16px;
        text-align: left;
        user-select: none;
    }
    
    .logs-table td {
        padding: 16px;
        border-bottom: 1px solid #3a3a4a;
        color: #ccc;
        font-size: 13px;
        vertical-align: top;
    }
    
    .logs-table tr:last-child td {
        border-bottom: none;
    }
    
    .logs-table tr:hover td {
        background-color: #2a2a3a;
    }
    
    /* 状态徽章 */
    .status-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    /* 用户信息样式 */
    .user-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    
    .user-name {
        font-weight: 500;
        color: #fff;
    }
    
    .user-email {
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    
    /* API接口名称样式 */
    .api-name-container {
        max-width: 150px;
    }
    
    /* 视频URL样式 */
    .video-url-container {
        transition: background-color 0.2s, border-color 0.2s;
    }
    
    .video-url-container:hover {
        background-color: #3a3a4a;
        border-color: #4dabf7;
    }
    
    /* 复制按钮交互效果 */
    .copy-video-url-btn {
        transition: all 0.2s !important;
    }
    
    .copy-video-url-btn:hover {
        background-color: #4dabf7 !important;
        transform: scale(1.05);
    }
    
    .status-success {
        background-color: rgba(40, 167, 69, 0.2);
        color: #28a745;
        border: 1px solid rgba(40, 167, 69, 0.3);
    }
    
    .status-error {
        background-color: rgba(220, 53, 69, 0.2);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.3);
    }
    
    /* 分页 */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-top: 24px;
    }
    
    .pagination-info {
        color: #999;
        font-size: 13px;
    }
    
    .pagination-button {
        padding: 8px 16px;
        background-color: #2a2a3a;
        color: #fff;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.2s;
    }
    
    .pagination-button:hover:not(:disabled) {
        background-color: #ff6768;
    }
    
    .pagination-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    /* 空状态 */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }
    
    .empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
        opacity: 0.5;
    }
    
    .empty-title {
        font-size: 18px;
        margin-bottom: 8px;
        color: #999;
    }
    
    .empty-description {
        font-size: 14px;
        margin-bottom: 24px;
    }
    
    /* 工具提示 */
    .tooltip {
        position: relative;
        text-decoration: underline dotted #999;
        cursor: help;
    }
    
    .tooltip:hover::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background-color: #000;
        color: #fff;
        padding: 8px 12px;
        border-radius: 4px;
        font-size: 12px;
        white-space: nowrap;
        z-index: 1000;
        margin-bottom: 8px;
    }
    
    /* 响应式设计 */
    @media (max-width: 768px) {
        .filter-row {
            flex-direction: column;
            align-items: stretch;
        }
        
        .logs-table {
            display: block;
            overflow-x: auto;
        }
        
        .logs-table th, .logs-table td {
            min-width: 120px;
        }
    }
</style>

<div class="main-container">
    <div class="page-header">
        <div>
            <h1>API调用记录</h1>
            <p class="subtitle">查看和管理视频解析API调用日志</p>
        </div>
        <a href="/admin" class="btn btn-secondary">← 返回管理后台</a>
    </div>
    
    <!-- 统计卡片 -->
    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-value"><%= total_logs.toLocaleString() %></div>
            <div class="stat-label">总调用次数</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-value"><%= today_calls.toLocaleString() %></div>
            <div class="stat-label">今日调用</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-value"><%= success_rate %>%</div>
            <div class="stat-label">成功率</div>
        </div>
        
        <div class="stat-card">
            <div class="stat-value"><%= Math.round(avg_response_time) %>ms</div>
            <div class="stat-label">平均响应时间</div>
            <div class="stat-note">(仅统计有响应时间的记录)</div>
        </div>
    </div>
    
    <!-- 过滤器面板 -->
    <div class="filter-panel">
        <div class="filter-title">筛选条件</div>
        <form method="get" action="/admin/call-logs" class="filter-form">
            <div class="filter-row">
                <div class="filter-field">
                    <label class="filter-label">页码</label>
                    <select name="page" class="filter-select" onchange="this.form.submit()">
                        <% for(let i = 1; i <= total_pages; i++) { %>
                        <option value="<%= i %>" <%= i === page ? 'selected' : '' %>>第 <%= i %> 页</option>
                        <% } %>
                    </select>
                </div>
                
                <div class="filter-field">
                    <label class="filter-label">每页显示</label>
                    <select name="limit" class="filter-select" onchange="this.form.submit()">
                        <option value="20" <%= limit === 20 ? 'selected' : '' %>>20 条</option>
                        <option value="50" <%= limit === 50 ? 'selected' : '' %>>50 条</option>
                        <option value="100" <%= limit === 100 ? 'selected' : '' %>>100 条</option>
                        <option value="200" <%= limit === 200 ? 'selected' : '' %>>200 条</option>
                    </select>
                </div>
                
                <div class="filter-field">
                    <label class="filter-label">状态</label>
                    <select name="status" class="filter-select" onchange="this.form.submit()">
                        <option value="all" <%= current_status === 'all' ? 'selected' : '' %>>全部状态</option>
                        <option value="success" <%= current_status === 'success' ? 'selected' : '' %>>仅成功</option>
                        <option value="error" <%= current_status === 'error' ? 'selected' : '' %>>仅失败</option>
                    </select>
                </div>
                
                <div class="filter-field">
                    <label class="filter-label">API类型</label>
                    <select name="api_type" class="filter-select" onchange="this.form.submit()">
                        <option value="all" <%= current_api_type === 'all' ? 'selected' : '' %>>全部类型</option>
                        <option value="smart_parse" <%= current_api_type === 'smart_parse' ? 'selected' : '' %>>智能解析</option>
                        <option value="quick_parse" <%= current_api_type === 'quick_parse' ? 'selected' : '' %>>快速解析</option>
                        <!-- 批量解析和测试解析已移除，因为它们不常用 -->
                    </select>
                </div>
            </div>
            
            <div class="filter-actions">
                <button type="submit" class="btn btn-primary">应用筛选</button>
                <a href="/admin/call-logs?limit=<%= limit %>" class="btn btn-secondary">重置筛选</a>
            </div>
        </form>
    </div>
    
    <!-- 调用记录表格 -->
    <% if (error) { %>
    <div class="card">
        <div class="flash-message flash-error">
            <strong>错误:</strong> <%= error %>
        </div>
    </div>
    <% } else if (logs.length === 0) { %>
    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <div class="empty-title">暂无调用记录</div>
        <div class="empty-description">用户还没有进行任何视频解析操作</div>
        <a href="/" class="btn btn-primary" target="_blank">去进行视频解析</a>
    </div>
    <% } else { %>
    <div class="logs-table-wrapper">
        <table class="logs-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>时间</th>
                    <th>用户</th>
                    <th>API类型</th>
                    <th>解析接口</th>
                    <th>视频URL</th>
                    <th>状态</th>
                    <th>响应时间</th>
                    <th>错误信息</th>
                </tr>
            </thead>
            <tbody>
                <% logs.forEach(function(log) { %>
                <tr>
                    <td><%= log.id %></td>
                    <td title="<%= log.created_at %>">
                        <%= formatChinaTime(log.created_at) %>
                    </td>
                    <td>
                        <% if (log.user_username) { %>
                        <div class="user-info">
                            <div class="user-name"><%= log.user_username %></div>
                            <% if (log.user_email) { %>
                            <div class="user-email" style="font-size: 11px; color: #666;"><%= log.user_email %></div>
                            <% } %>
                            <% if (log.user_id) { %>
                            <div class="user-id" style="font-size: 11px; color: #999;">ID: <%= log.user_id %></div>
                            <% } %>
                        </div>
                        <% } else if (log.user_id) { %>
                        用户ID: <%= log.user_id %>
                        <% } else { %>
                        游客
                        <% } %>
                    </td>
                    <td>
                        <% const apiTypeMap = { 
                            'smart_parse': '智能解析',
                            'quick_parse': '快速解析'
                            // 'bulk_parse': '批量解析' 已移除，不常用
                            // 'test_parse': '测试解析' 已移除，不常用
                        }; %>
                        <%= apiTypeMap[log.api_type] || log.api_type || '未知' %>
                    </td>
                    <td>
                        <% if (log.api_name) { %>
                        <div><%= log.api_name %></div>
                        <% if (log.api_id) { %>
                        <div style="font-size: 11px; color: #666;">ID: <%= log.api_id %></div>
                        <% } %>
                        <% } else { %>
                        未知接口
                        <% } %>
                    </td>
                    <td>
                        <% if (log.video_url) { %>
                        <div class="video-url-wrapper" style="position: relative; max-width: 200px;">
                            <div class="video-url-container" style="display: flex; align-items: center; gap: 8px; background-color: #2a2a3a; padding: 6px 10px; border-radius: 6px; border: 1px solid #3a3a4a;">
                                <% if (log.video_url.includes('http')) { %>
                                <a href="<%= log.video_url %>" target="_blank" rel="noopener" 
                                   style="text-decoration: none; color: #4dabf7; flex: 1; min-width: 0;">
                                    <div style="font-size: 12px; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <%= log.video_url %>
                                    </div>
                                </a>
                                <% } else { %>
                                <div style="font-size: 12px; color: #999; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <%= log.video_url %>
                                </div>
                                <% } %>
                                <button class="copy-video-url-btn" onclick="copyVideoUrl('<%= log.id %>', '<%= log.video_url %>')" 
                                        style="padding: 4px 8px; font-size: 11px; background-color: #3a3a5a; border: none; border-radius: 4px; color: #fff; cursor: pointer; min-width: 45px; transition: background-color 0.2s;">
                                    复制
                                </button>
                            </div>
                        </div>
                        <% } else { %>
                        <span style="color: #666; font-size: 12px;">无URL</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (log.success) { %>
                        <span class="status-badge status-success">成功</span>
                        <% } else { %>
                        <span class="status-badge status-error">失败</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (log.response_time_ms) { %>
                        <span class="tooltip" data-tooltip="<%= log.response_time_ms.toLocaleString() %> 毫秒">
                            <%= log.response_time_ms.toLocaleString() %>ms
                        </span>
                        <% } else { %>
                        <span style="color: #666;">-</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (log.error_message) { %>
                        <div style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #dc3545; font-size: 12px;"
                             title="<%= log.error_message %>">
                            <%= log.error_message %>
                        </div>
                        <% } else if (!log.success) { %>
                        <span style="color: #dc3545;">未知错误</span>
                        <% } else { %>
                        <span style="color: #666;">-</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    
    <!-- 分页 -->
    <% if (total_pages > 1) { %>
    <div class="pagination">
        <button class="pagination-button" <%= has_prev ? '' : 'disabled' %> onclick="window.location.href='/admin/call-logs?page=<%= page-1 %>&limit=<%= limit %><%= current_status !== 'all' ? '&status=' + current_status : '' %><%= current_api_type !== 'all' ? '&api_type=' + current_api_type : '' %>'">
            上一页
        </button>
        
        <div class="pagination-info">
            第 <%= page %> / <%= total_pages %> 页 • 共 <%= total_logs.toLocaleString() %> 条记录
        </div>
        
        <button class="pagination-button" <%= has_next ? '' : 'disabled' %> onclick="window.location.href='/admin/call-logs?page=<%= page+1 %>&limit=<%= limit %><%= current_status !== 'all' ? '&status=' + current_status : '' %><%= current_api_type !== 'all' ? '&api_type=' + current_api_type : '' %>'">
            下一页
        </button>
    </div>
    <% } %>
    <% } %>
</div>

<!-- 复制视频URL功能 -->
<script>
// 复制视频URL到剪贴板
function copyVideoUrl(logId, url) {
    // 如果URL为空，则不需要复制
    if (!url || url.trim() === '') return;
    
    try {
        // 使用新的Clipboard API
        navigator.clipboard.writeText(url).then(() => {
            // 成功提示
            const btn = event.target;
            const originalText = btn.textContent;
            
            // 更新按钮文字
            btn.textContent = '✓ 已复制';
            btn.style.backgroundColor = '#28a745';
            btn.style.color = '#fff';
            
            // 3秒后恢复
            setTimeout(() => {
                btn.textContent = originalText;
                btn.style.backgroundColor = '#3a3a5a';
                btn.style.color = '#fff';
            }, 3000);
            
            // 控制台日志
            console.log(`[调用记录] 已复制日志ID ${logId} 的视频URL: ${url.substring(0, 50)}${url.length > 50 ? '...' : ''}`);
        }).catch(err => {
            console.error('复制失败:', err);
            
            // 备用方法：使用较旧的API
            const textArea = document.createElement('textarea');
            textArea.value = url;
            document.body.appendChild(textArea);
            textArea.select();
            try {
                document.execCommand('copy');
                alert('已复制视频URL: ' + url.substring(0, 80) + (url.length > 80 ? '...' : ''));
            } catch (err2) {
                console.error('备用复制方法也失败:', err2);
                alert('复制失败，请手动复制URL');
            }
            document.body.removeChild(textArea);
        });
    } catch (error) {
        console.error('复制异常:', error);
        // 最后一个备用方案
        prompt('请手动复制以下URL:', url);
    }
}

// 更新管理后台菜单
document.addEventListener('DOMContentLoaded', function() {
    // 这里可以添加更多的交互功能
    console.log('调用记录页面已加载');
    
    // 添加键盘快捷键
    document.addEventListener('keydown', function(e) {
        // 左箭头键：上一页
        if (e.key === 'ArrowLeft' && <%= has_prev ? 'true' : 'false' %>) {
            window.location.href = '/admin/call-logs?page=<%= page-1 %>&limit=<%= limit %><%= current_status !== 'all' ? '&status=' + current_status : '' %><%= current_api_type !== 'all' ? '&api_type=' + current_api_type : '' %>';
        }
        // 右箭头键：下一页
        if (e.key === 'ArrowRight' && <%= has_next ? 'true' : 'false' %>) {
            window.location.href = '/admin/call-logs?page=<%= page+1 %>&limit=<%= limit %><%= current_status !== 'all' ? '&status=' + current_status : '' %><%= current_api_type !== 'all' ? '&api_type=' + current_api_type : '' %>';
        }
        // ESC键：返回后台
        if (e.key === 'Escape') {
            window.location.href = '/admin';
        }
    });
});
</script>