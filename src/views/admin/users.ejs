<%- include('../partials/header', { title: '用户管理', currentPage: 'admin' }) %>

<style>
    .main-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }
    
    .page-header {
        margin-bottom: 32px;
    }
    
    .page-header h1 {
        font-size: 28px;
        margin-bottom: 8px;
    }
    
    .page-header a {
        color: #999;
        text-decoration: none;
        font-size: 14px;
    }
    
    .page-header a:hover {
        color: #ff6768;
    }
    
    .card {
        background-color: #252532;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
    }
    
    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid #3a3a4a;
    }
    
    .card-title {
        font-size: 18px;
        font-weight: 600;
    }
    
    .btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
    }
    
    .btn-primary {
        background-color: #ff6768;
        color: #fff;
    }
    
    .btn-primary:hover {
        background-color: #ff5252;
    }
    
    .btn-secondary {
        background-color: #3a3a4a;
        color: #fff;
    }
    
    .btn-secondary:hover {
        background-color: #4a4a5a;
    }
    
    .btn-sm {
        padding: 4px 12px;
        font-size: 12px;
    }
    
    .btn-danger {
        background-color: #dc3545;
        color: #fff;
    }
    
    .btn-danger:hover {
        background-color: #c82333;
    }
    
    .table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .table th, .table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #3a3a4a;
    }
    
    .table th {
        color: #666;
        font-weight: 500;
        font-size: 13px;
    }
    
    .table tr:hover {
        background-color: #2a2a3a;
    }
    
    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
    }
    
    .badge-success {
        background-color: rgba(40, 167, 69, 0.2);
        color: #5cdb7a;
    }
    
    .badge-admin {
        background-color: rgba(255, 103, 104, 0.2);
        color: #ff6768;
    }
    
    .actions {
        display: flex;
        gap: 8px;
    }
    
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.7);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background-color: #252532;
        border-radius: 12px;
        padding: 24px;
        max-width: 400px;
        width: 90%;
    }
    
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    
    .modal-title {
        font-size: 18px;
        font-weight: 600;
    }
    
    .modal-close {
        background: none;
        border: none;
        color: #999;
        font-size: 24px;
        cursor: pointer;
    }
    
    .form-group {
        margin-bottom: 16px;
    }
    
    .form-label {
        display: block;
        color: #999;
        font-size: 14px;
        margin-bottom: 6px;
    }
    
    .form-input {
        width: 100%;
        padding: 10px 14px;
        background-color: #1e1e2f;
        border: 1px solid #3a3a4a;
        border-radius: 6px;
        color: #fff;
        font-size: 14px;
    }
    
    .form-input:focus {
        outline: none;
        border-color: #ff6768;
    }
    
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
    }
    
    .password-wrapper {
        position: relative;
    }
    
    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #666;
        cursor: pointer;
        padding: 4px;
    }
    
    .password-toggle:hover {
        color: #ff6768;
    }
    
    .form-input.with-toggle {
        padding-right: 40px;
    }
    
    .password-strength {
        height: 0;
        opacity: 0;
        overflow: hidden;
        transition: height 0.2s, opacity 0.2s;
    }

    .password-strength.visible {
        height: 4px;
        opacity: 1;
    }

    .password-strength-bar {
        height: 100%;
        width: 0%;
        transition: all 0.3s;
    }

    .password-strength-bar.weak { width: 33%; background: #dc3545; }
    .password-strength-bar.medium { width: 66%; background: #ffc107; }
    .password-strength-bar.strong { width: 100%; background: #28a745; }

    .strength-text {
        font-size: 12px;
        color: #666;
        margin-top: 4px;
    }

    .password-match {
        font-size: 12px;
        margin-top: 4px;
    }

    .password-match.match { color: #28a745; }
    .password-match.mismatch { color: #dc3545; }

    .confirm-group {
        margin-top: 16px;
    }

</style>

<div class="main-container">
    <div class="page-header">
        <a href="/admin">← 返回管理后台</a>
        <h1 style="margin-top: 12px;">用户管理</h1>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">用户列表 (共 <%= users.length %> 个)</h3>
        </div>
        
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>用户名</th>
                    <th>邮箱</th>
                    <th>角色</th>
                    <th>注册时间</th>
                    <th>最后登录</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(function(u) { %>
                <tr>
                    <td><%= u.id %></td>
                    <td><%= u.username %></td>
                    <td><%= u.email %></td>
                    <td>
                        <% if (u.is_admin) { %>
                        <span class="badge badge-admin">管理员</span>
                        <% } else { %>
                        <span class="badge badge-success">普通用户</span>
                        <% } %>
                    </td>
                    <td><%= formatChinaTime(u.created_at, '%Y-%m-%d') %></td>
                    <td><%= u.last_login ? formatChinaTime(u.last_login, '%m-%d %H:%M') : '从未' %></td>
                    <td class="actions">
                        <% if (u.id !== user.id) { %>
                        <button class="btn btn-secondary btn-sm" onclick="toggleAdmin(<%= u.id %>, <%= !u.is_admin %>)">
                            <%= u.is_admin ? '取消管理' : '设为管理' %>
                        </button>
                        <button class="btn btn-secondary btn-sm" onclick="showResetPassword(<%= u.id %>)">重置密码</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')">删除</button>
                        <% } else { %>
                        <span style="color: #666; font-size: 12px; margin-right: 8px;">当前用户</span>
                        <button class="btn btn-secondary btn-sm" onclick="showChangeOwnPassword()">修改密码</button>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<!-- 修改当前管理员密码模态框 -->
<div id="changeOwnPasswordModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">修改当前账户密码</h3>
            <button class="modal-close" onclick="closeChangeOwnPasswordModal()">&times;</button>
        </div>
        <form id="changeOwnPasswordForm">
            <div class="form-group">
                <label class="form-label">旧密码</label>
                <div class="password-wrapper">
                    <input type="password" id="ownOldPassword" class="form-input with-toggle" required placeholder="请输入当前密码">
                    <button type="button" class="password-toggle" onclick="togglePassword('ownOldPassword')">👁️</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">新密码</label>
                <div class="password-wrapper">
                    <input type="password" id="ownNewPassword" class="form-input with-toggle" required minlength="6" placeholder="至少6个字符">
                    <button type="button" class="password-toggle" onclick="togglePassword('ownNewPassword')">👁️</button>
                </div>
                <div class="password-strength" id="ownStrengthContainer">
                    <div class="password-strength-bar" id="ownStrengthBar"></div>
                </div>
                <div class="strength-text" id="ownStrengthText">请输入新密码</div>
            </div>
            <div class="form-group confirm-group">
                <label class="form-label">确认密码</label>
                <div class="password-wrapper">
                    <input type="password" id="ownConfirmPassword" class="form-input with-toggle" required minlength="6" placeholder="再次输入密码">
                    <button type="button" class="password-toggle" onclick="togglePassword('ownConfirmPassword')">👁️</button>
                </div>
                <div class="password-match" id="ownMatchText"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeChangeOwnPasswordModal()">取消</button>
                <button type="submit" class="btn btn-primary" id="ownSubmitBtn" disabled>确认修改</button>
            </div>
        </form>
    </div>
</div>

<!-- 重置密码模态框 -->
<div id="resetModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">重置用户密码</h3>
            <button class="modal-close" onclick="closeResetModal()">&times;</button>
        </div>
        <form id="resetForm">
            <input type="hidden" id="resetUserId">
            <div class="form-group">
                <label class="form-label">新密码</label>
                <div class="password-wrapper">
                    <input type="password" id="newPassword" class="form-input with-toggle" required minlength="6" placeholder="至少6个字符">
                    <button type="button" class="password-toggle" onclick="togglePassword('newPassword')">👁️</button>
                </div>
                <div class="password-strength">
                    <div class="password-strength-bar" id="strengthBar"></div>
                </div>
                <div class="strength-text" id="strengthText">请输入密码</div>
            </div>
            <div class="form-group confirm-group">
                <label class="form-label">确认密码</label>
                <div class="password-wrapper">
                    <input type="password" id="confirmPassword" class="form-input with-toggle" required minlength="6" placeholder="再次输入密码">
                    <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')">👁️</button>
                </div>
                <div class="password-match" id="matchText"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeResetModal()">取消</button>
                <button type="submit" class="btn btn-primary" id="submitBtn" disabled>确认重置</button>
            </div>
        </form>
    </div>
</div>

<script>
    // 密码显示/隐藏切换
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        const button = input.nextElementSibling;
        if (input.type === 'password') {
            input.type = 'text';
            button.textContent = '🙈';
        } else {
            input.type = 'password';
            button.textContent = '👁️';
        }
    }
    
    // 密码强度检测
    function checkPasswordStrength(password) {
        if (!password) return { level: 0, text: '请输入密码' };
        
        let score = 0;
        if (password.length >= 6) score++;
        if (password.length >= 8) score++;
        if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
        if (/\d/.test(password)) score++;
        if (/[!@#$%^&*(),.?":{}|<>]/.test(password)) score++;
        
        if (score <= 2) return { level: 1, text: '弱 - 建议包含大小写字母、数字和特殊字符' };
        if (score <= 3) return { level: 2, text: '中等' };
        return { level: 3, text: '强' };
    }
    
    // 监听密码输入
    const newPwdInput = document.getElementById('newPassword');
    const confirmPwdInput = document.getElementById('confirmPassword');
    const strengthBar = document.getElementById('strengthBar');
    const strengthText = document.getElementById('strengthText');
    const matchText = document.getElementById('matchText');
    const submitBtn = document.getElementById('submitBtn');
    
    newPwdInput.addEventListener('input', function() {
        const strengthContainer = strengthBar.parentElement;
        if (this.value) {
            strengthContainer.classList.add('visible');
        } else {
            strengthContainer.classList.remove('visible');
            strengthText.textContent = '请输入密码';
        }

        const result = checkPasswordStrength(this.value);
        strengthBar.className = 'password-strength-bar';
        if (result.level === 1) strengthBar.classList.add('weak');
        else if (result.level === 2) strengthBar.classList.add('medium');
        else if (result.level === 3) strengthBar.classList.add('strong');
        strengthText.textContent = result.text;

        if (confirmPwdInput.value) {
            checkMatch();
        }
    });
    
    confirmPwdInput.addEventListener('input', checkMatch);
    
    function checkMatch() {
        const newPwd = newPwdInput.value;
        const confirmPwd = confirmPwdInput.value;
        
        if (!confirmPwd) {
            matchText.textContent = '';
            matchText.className = 'password-match';
            submitBtn.disabled = true;
            return;
        }
        
        if (newPwd === confirmPwd && newPwd.length >= 6) {
            matchText.textContent = '✓ 密码一致';
            matchText.className = 'password-match match';
            submitBtn.disabled = false;
        } else {
            matchText.textContent = '✗ 密码不一致';
            matchText.className = 'password-match mismatch';
            submitBtn.disabled = true;
        }
    }
    
    function showResetPassword(userId) {
        document.getElementById('resetUserId').value = userId;
        document.getElementById('newPassword').value = '';
        document.getElementById('confirmPassword').value = '';
        strengthBar.className = 'password-strength-bar';
        strengthBar.parentElement.classList.remove('visible');
        strengthText.textContent = '请输入密码';
        matchText.textContent = '';
        submitBtn.disabled = true;
        document.getElementById('resetModal').classList.add('active');
    }
    
    function closeResetModal() {
        document.getElementById('resetModal').classList.remove('active');
    }
    
    async function toggleAdmin(userId, becomeAdmin) {
        if (!confirm(becomeAdmin ? '确定要设置此用户为管理员吗？' : '确定要取消此用户的管理员权限吗？')) {
            return;
        }
        
        try {
            const response = await fetch(`/admin/users/${userId}/toggle-admin`, { method: 'POST' });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert(result.message || '操作失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    }
    
    document.getElementById('resetForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const userId = document.getElementById('resetUserId').value;
        const password = document.getElementById('newPassword').value;
        
        try {
            const response = await fetch(`/admin/users/${userId}/reset-password`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('密码重置成功');
                closeResetModal();
                strengthBar.parentElement.classList.remove('visible');
            } else {
                alert(result.message || '操作失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    });
    
    async function deleteUser(userId, username) {
        if (!confirm(`确定要删除用户 "${username}" 吗？此操作不可恢复！`)) {
            return;
        }

        try {
            const response = await fetch(`/admin/users/${userId}`, { method: 'DELETE' });
            const result = await response.json();

            if (result.success) {
                location.reload();
            } else {
                alert(result.message || '删除失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    }

    // 修改当前管理员密码
    function showChangeOwnPassword() {
        document.getElementById('ownOldPassword').value = '';
        document.getElementById('ownNewPassword').value = '';
        document.getElementById('ownConfirmPassword').value = '';
        document.getElementById('ownStrengthBar').className = 'password-strength-bar';
        document.getElementById('ownStrengthBar').parentElement.classList.remove('visible');
        document.getElementById('ownStrengthText').textContent = '请输入新密码';
        document.getElementById('ownMatchText').textContent = '';
        document.getElementById('ownSubmitBtn').disabled = true;
        document.getElementById('changeOwnPasswordModal').classList.add('active');
    }

    function closeChangeOwnPasswordModal() {
        document.getElementById('changeOwnPasswordModal').classList.remove('active');
    }

    const ownNewPwdInput = document.getElementById('ownNewPassword');
    const ownConfirmPwdInput = document.getElementById('ownConfirmPassword');
    const ownStrengthBar = document.getElementById('ownStrengthBar');
    const ownStrengthText = document.getElementById('ownStrengthText');
    const ownMatchText = document.getElementById('ownMatchText');
    const ownSubmitBtn = document.getElementById('ownSubmitBtn');

    ownNewPwdInput.addEventListener('input', function() {
        const result = checkPasswordStrength(this.value);
        ownStrengthBar.className = 'password-strength-bar';
        if (result.level === 1) ownStrengthBar.classList.add('weak');
        else if (result.level === 2) ownStrengthBar.classList.add('medium');
        else if (result.level === 3) ownStrengthBar.classList.add('strong');
        ownStrengthText.textContent = result.text;

        if (ownConfirmPwdInput.value) {
            checkOwnMatch();
        }
    });

    ownConfirmPwdInput.addEventListener('input', checkOwnMatch);

    function checkOwnMatch() {
        const newPwd = ownNewPwdInput.value;
        const confirmPwd = ownConfirmPwdInput.value;

        if (!confirmPwd) {
            ownMatchText.textContent = '';
            ownMatchText.className = 'password-match';
            ownSubmitBtn.disabled = true;
            return;
        }

        if (newPwd === confirmPwd && newPwd.length >= 6) {
            ownMatchText.textContent = '✓ 密码一致';
            ownMatchText.className = 'password-match match';
            ownSubmitBtn.disabled = false;
        } else {
            ownMatchText.textContent = '✗ 密码不一致';
            ownMatchText.className = 'password-match mismatch';
            ownSubmitBtn.disabled = true;
        }
    }

    document.getElementById('changeOwnPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const old_password = document.getElementById('ownOldPassword').value;
        const new_password = document.getElementById('ownNewPassword').value;

        try {
            const response = await fetch('/admin/users/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ old_password, new_password })
            });

            const result = await response.json();

            if (result.success) {
                alert('密码修改成功');
                closeChangeOwnPasswordModal();
                document.getElementById('ownStrengthBar').parentElement.classList.remove('visible');
            } else {
                alert(result.message || '修改失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    });
</script>

</body>
</html>
