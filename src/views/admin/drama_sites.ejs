<%- include('../partials/header', { title: '影视导航管理', currentPage: 'admin' }) %>

<style>
    .main-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
    }
    
    .page-header {
        margin-bottom: 32px;
    }
    
    .page-header h1 {
        font-size: 28px;
        margin-bottom: 8px;
    }
    
    .page-header a {
        color: #999;
        text-decoration: none;
        font-size: 14px;
    }
    
    .page-header a:hover {
        color: #ff6768;
    }
    
    .card {
        background-color: #252532;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
    }
    
    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid #3a3a4a;
    }
    
    .card-title {
        font-size: 18px;
        font-weight: 600;
    }
    
    .btn {
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
    }
    
    .btn-primary {
        background-color: #ff6768;
        color: #fff;
    }
    
    .btn-primary:hover {
        background-color: #ff5252;
    }
    
    .btn-secondary {
        background-color: #3a3a4a;
        color: #fff;
    }
    
    .btn-secondary:hover {
        background-color: #4a4a5a;
    }
    
    .btn-sm {
        padding: 4px 12px;
        font-size: 12px;
    }
    
    .btn-danger {
        background-color: #dc3545;
        color: #fff;
    }
    
    .btn-danger:hover {
        background-color: #c82333;
    }
    
    .sites-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
    }
    
    .site-card {
        background-color: #1e1e2f;
        border-radius: 8px;
        padding: 16px;
        transition: all 0.2s;
    }
    
    .site-card:hover {
        background-color: #2a2a3a;
    }
    
    .site-card.disabled {
        opacity: 0.5;
    }
    
    .site-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    
    .site-icon {
        font-size: 32px;
    }
    
    .site-info {
        flex: 1;
    }
    
    .site-name {
        font-weight: 500;
        margin-bottom: 2px;
    }
    
    .site-url {
        color: #666;
        font-size: 12px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    
    .site-description {
        color: #999;
        font-size: 13px;
        margin-bottom: 12px;
    }
    
    .site-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .toggle-switch {
        position: relative;
        width: 44px;
        height: 24px;
        background-color: #3a3a4a;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .toggle-switch.active {
        background-color: #ff6768;
    }
    
    .toggle-switch::after {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        width: 20px;
        height: 20px;
        background-color: #fff;
        border-radius: 50%;
        transition: all 0.2s;
    }
    
    .toggle-switch.active::after {
        left: 22px;
    }
    
    .site-actions {
        display: flex;
        gap: 8px;
    }
    
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.7);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background-color: #252532;
        border-radius: 12px;
        padding: 24px;
        max-width: 500px;
        width: 90%;
    }
    
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    
    .modal-title {
        font-size: 18px;
        font-weight: 600;
    }
    
    .modal-close {
        background: none;
        border: none;
        color: #999;
        font-size: 24px;
        cursor: pointer;
    }
    
    .form-group {
        margin-bottom: 16px;
    }
    
    .form-label {
        display: block;
        color: #999;
        font-size: 14px;
        margin-bottom: 6px;
    }
    
    .form-input {
        width: 100%;
        padding: 10px 14px;
        background-color: #1e1e2f;
        border: 1px solid #3a3a4a;
        border-radius: 6px;
        color: #fff;
        font-size: 14px;
    }
    
    .form-input:focus {
        outline: none;
        border-color: #ff6768;
    }
    
    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
    }
    
    .empty-state {
        text-align: center;
        padding: 40px;
        color: #666;
    }
</style>

<div class="main-container">
    <div class="page-header">
        <a href="/admin">← 返回管理后台</a>
        <h1 style="margin-top: 12px;">影视导航管理</h1>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">导航站点列表 (<%= sites.length %> 个)</h3>
            <button class="btn btn-primary" onclick="showAddModal()">+ 添加站点</button>
        </div>
        
        <div class="sites-grid">
            <% if (sites.length > 0) { %>
            <% sites.forEach(function(site) { %>
            <div class="site-card <%= site.is_enabled ? '' : 'disabled' %>" data-id="<%= site.id %>">
                <div class="site-header">
                    <span class="site-icon"><%= site.icon %></span>
                    <div class="site-info">
                        <div class="site-name"><%= site.name %></div>
                        <div class="site-url"><%= site.url %></div>
                    </div>
                </div>
                <p class="site-description"><%= site.description || '暂无描述' %></p>
                <div class="site-footer">
                    <div class="toggle-switch <%= site.is_enabled ? 'active' : '' %>" onclick="toggleSite(<%= site.id %>)"></div>
                    <div class="site-actions">
                        <button class="btn btn-secondary btn-sm" onclick="showEditModal(<%= site.id %>, '<%= site.name %>', '<%= site.url %>', '<%= site.description || '' %>', '<%= site.icon %>')">编辑</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteSite(<%= site.id %>)">删除</button>
                    </div>
                </div>
            </div>
            <% }); %>
            <% } else { %>
            <div class="empty-state">
                <p>暂无导航站点，请点击上方按钮添加</p>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- 添加/编辑站点模态框 -->
<div id="siteModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="modalTitle">添加站点</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <form id="siteForm">
            <input type="hidden" id="siteId">
            <div class="form-group">
                <label class="form-label">站点名称</label>
                <input type="text" id="siteName" class="form-input" required placeholder="例如：影巢movie">
            </div>
            <div class="form-group">
                <label class="form-label">站点URL</label>
                <input type="text" id="siteUrl" class="form-input" required placeholder="例如：https://www.movie1080.xyz/">
            </div>
            <div class="form-group">
                <label class="form-label">描述</label>
                <input type="text" id="siteDesc" class="form-input" placeholder="例如：高清影视资源，美日韩剧优选">
            </div>
            <div class="form-group">
                <label class="form-label">图标 (emoji)</label>
                <input type="text" id="siteIcon" class="form-input" placeholder="例如：🎬" value="🎬">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">取消</button>
                <button type="submit" class="btn btn-primary">保存</button>
            </div>
        </form>
    </div>
</div>

<script>
    function showAddModal() {
        document.getElementById('modalTitle').textContent = '添加站点';
        document.getElementById('siteId').value = '';
        document.getElementById('siteName').value = '';
        document.getElementById('siteUrl').value = '';
        document.getElementById('siteDesc').value = '';
        document.getElementById('siteIcon').value = '🎬';
        document.getElementById('siteModal').classList.add('active');
    }
    
    function showEditModal(id, name, url, description, icon) {
        document.getElementById('modalTitle').textContent = '编辑站点';
        document.getElementById('siteId').value = id;
        document.getElementById('siteName').value = name;
        document.getElementById('siteUrl').value = url;
        document.getElementById('siteDesc').value = description;
        document.getElementById('siteIcon').value = icon || '🎬';
        document.getElementById('siteModal').classList.add('active');
    }
    
    function closeModal() {
        document.getElementById('siteModal').classList.remove('active');
    }
    
    document.getElementById('siteForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const id = document.getElementById('siteId').value;
        const name = document.getElementById('siteName').value.trim();
        const url = document.getElementById('siteUrl').value.trim();
        const description = document.getElementById('siteDesc').value.trim();
        const icon = document.getElementById('siteIcon').value.trim() || '🎬';
        
        try {
            let response;
            if (id) {
                response = await fetch(`/admin/drama-sites/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, url, description, icon })
                });
            } else {
                response = await fetch('/admin/drama-sites/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, url, description, icon })
                });
            }
            
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert(result.message || '操作失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    });
    
    async function toggleSite(id) {
        try {
            const response = await fetch(`/admin/drama-sites/${id}/toggle`, { method: 'POST' });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            }
        } catch (error) {
            alert('请求失败');
        }
    }
    
    async function deleteSite(id) {
        if (!confirm('确定要删除这个站点吗？')) return;
        
        try {
            const response = await fetch(`/admin/drama-sites/${id}`, { method: 'DELETE' });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            }
        } catch (error) {
            alert('请求失败');
        }
    }
</script>

</body>
</html>
