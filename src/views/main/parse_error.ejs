<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || '错误' %> - AudioVisual</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #1e1e2f;
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .error-container {
            text-align: center;
            padding: 40px;
        }
        
        .error-icon {
            font-size: 80px;
            margin-bottom: 24px;
        }
        
        .error-code {
            font-size: 120px;
            font-weight: bold;
            color: #ff6768;
            line-height: 1;
        }
        
        .error-title {
            font-size: 24px;
            margin: 16px 0;
        }
        
        .error-message {
            color: #999;
            margin-bottom: 32px;
            font-size: 16px;
        }
        
        .btn {
            display: inline-block;
            padding: 12px 32px;
            background-color: #ff6768;
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
            font-size: 16px;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background-color: #ff5252;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-icon">
            <% if (title && title.includes('404')) { %>
            🔍
            <% } else { %>
            ⚠️
            <% } %>
        </div>
        <div class="error-code"><%= typeof statusCode !== 'undefined' ? statusCode : (title && title.includes('404') ? '404' : '500') %></div>
        <h1 class="error-title"><%= title || '出错了' %></h1>
        <p class="error-message"><%= message || '发生了一个错误' %></p>
        <a href="/" class="btn">返回首页</a>
    </div>
</body>
</html>
