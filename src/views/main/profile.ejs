<%- include('../partials/header', { title: '个人中心' }) %>

<style>
    .main-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
    }
    
    .profile-header {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
    }
    
    .avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #ff6768 0%, #ff5252 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: bold;
        color: #fff;
    }
    
    .profile-info h1 {
        font-size: 24px;
        margin-bottom: 4px;
    }
    
    .profile-info p {
        color: #999;
        font-size: 14px;
    }
    
    .profile-badge {
        display: inline-block;
        background-color: #ff6768;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        margin-top: 8px;
    }
    
    .card {
        background-color: #252532;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
    }
    
    .card-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid #3a3a4a;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }
    
    .info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    
    .info-label {
        color: #666;
        font-size: 13px;
    }
    
    .info-value {
        color: #fff;
        font-size: 15px;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-label {
        display: block;
        color: #999;
        font-size: 14px;
        margin-bottom: 8px;
    }
    
    .form-input {
        width: 100%;
        padding: 12px 16px;
        background-color: #1e1e2f;
        border: 1px solid #3a3a4a;
        border-radius: 8px;
        color: #fff;
        font-size: 14px;
    }
    
    .form-input:focus {
        outline: none;
        border-color: #ff6768;
    }
    
    .btn {
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }
    
    .btn-primary {
        background-color: #ff6768;
        color: #fff;
    }
    
    .btn-primary:hover {
        background-color: #ff5252;
    }
    
    .btn-danger {
        background-color: #dc3545;
        color: #fff;
    }
    
    .btn-danger:hover {
        background-color: #c82333;
    }
    
    .api-key-display {
        background-color: #1e1e2f;
        border-radius: 8px;
        padding: 16px;
        margin-top: 12px;
    }
    
    .api-key-value {
        font-family: monospace;
        color: #ff6768;
        word-break: break-all;
        font-size: 13px;
        padding: 12px;
        background-color: #252532;
        border-radius: 6px;
        margin-bottom: 12px;
    }
    
    .api-key-actions {
        display: flex;
        gap: 12px;
    }
    
    .btn-sm {
        padding: 6px 16px;
        font-size: 13px;
    }
    
    .logs-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .logs-table th, .logs-table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #3a3a4a;
    }
    
    .logs-table th {
        color: #666;
        font-weight: 500;
        font-size: 13px;
    }
    
    .logs-table tr:hover {
        background-color: #2a2a3a;
    }
    
    .status-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
    }
    
    .status-success {
        background-color: rgba(40, 167, 69, 0.2);
        color: #5cdb7a;
    }
    
    .status-failed {
        background-color: rgba(220, 53, 69, 0.2);
        color: #ff6b7a;
    }
    
    .password-wrapper {
        position: relative;
    }
    
    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #666;
        cursor: pointer;
        padding: 4px;
    }
    
    .password-toggle:hover {
        color: #ff6768;
    }
    
    .form-input-wrapper {
        position: relative;
    }
    
    .form-input-wrapper input {
        padding-right: 40px;
    }
    
    .password-strength {
        height: 0;
        opacity: 0;
        overflow: hidden;
        transition: height 0.2s, opacity 0.2s;
    }

    .password-strength.visible {
        height: 4px;
        opacity: 1;
    }

    .password-strength-bar {
        height: 100%;
        width: 0%;
        transition: all 0.3s;
    }
    
    .password-strength-bar.weak { width: 33%; background: #dc3545; }
    .password-strength-bar.medium { width: 66%; background: #ffc107; }
    .password-strength-bar.strong { width: 100%; background: #28a745; }
    
    .strength-text {
        font-size: 12px;
        color: #666;
        margin-top: 4px;
    }
    
    .password-match {
        font-size: 12px;
        margin-top: 4px;
    }
    
    .password-match.match { color: #28a745; }
    .password-match.mismatch { color: #dc3545; }
    
    .error-text {
        color: #dc3545;
        font-size: 12px;
        margin-top: 4px;
    }
</style>

<div class="main-container">
    <div class="profile-header">
        <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <div class="profile-info">
            <h1><%= user.username %></h1>
            <p><%= user.email %></p>
            <% if (user.is_admin) { %>
            <span class="profile-badge">管理员</span>
            <% } %>
        </div>
    </div>
    
    <div class="card">
        <h2 class="card-title">账户信息</h2>
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">用户名</span>
                <span class="info-value"><%= user.username %></span>
            </div>
            <div class="info-item">
                <span class="info-label">邮箱</span>
                <span class="info-value"><%= user.email %></span>
            </div>
            <div class="info-item">
                <span class="info-label">注册时间</span>
                <span class="info-value"><%= formatChinaTime(user.created_at, '%Y-%m-%d %H:%M') %></span>
            </div>
            <div class="info-item">
                <span class="info-label">最后登录</span>
                <span class="info-value"><%= user.last_login ? formatChinaTime(user.last_login, '%Y-%m-%d %H:%M') : '从未登录' %></span>
            </div>
        </div>
    </div>
    
    <div class="card">
        <h2 class="card-title">修改密码</h2>
        <form id="passwordForm">
            <div class="form-group">
                <label class="form-label">旧密码</label>
                <div class="password-wrapper">
                    <input type="password" name="old_password" id="oldPassword" class="form-input" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('oldPassword')">👁️</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">新密码</label>
                <div class="password-wrapper">
                    <input type="password" name="new_password" id="newPassword" class="form-input" required minlength="6">
                    <button type="button" class="password-toggle" onclick="togglePassword('newPassword')">👁️</button>
                </div>
                <div class="password-strength">
                    <div class="password-strength-bar" id="strengthBar"></div>
                </div>
                <div class="strength-text" id="strengthText">请输入新密码</div>
            </div>
            <div class="form-group">
                <label class="form-label">确认密码</label>
                <div class="password-wrapper">
                    <input type="password" name="confirm_password" id="confirmPassword" class="form-input" required minlength="6">
                    <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')">👁️</button>
                </div>
                <div class="password-match" id="matchText"></div>
            </div>
            <button type="submit" class="btn btn-primary" id="submitBtn" disabled>修改密码</button>
        </form>
    </div>
    
    <div class="card">
        <h2 class="card-title">API Key</h2>
        <p style="color: #999; font-size: 14px; margin-bottom: 12px;">
            使用 API Key 可以无需登录即可调用解析接口，适合程序化调用场景。
        </p>
        
        <div id="apiKeyArea">
            <% if (user.api_key) { %>
            <div class="api-key-display">
                <div class="api-key-value" id="apiKeyValue">
                    <span id="apiKeyHidden">••••••••••••••••••••••••••••••••</span>
                    <span id="apiKeyRevealed" style="display:none;"><%= user.api_key %></span>
                </div>
                <div class="api-key-actions">
                    <button class="btn btn-secondary btn-sm" id="toggleBtn" onclick="toggleApiKeyVisibility()">显示</button>
                    <button class="btn btn-primary btn-sm" onclick="copyApiKey()">复制</button>
                    <button class="btn btn-danger btn-sm" onclick="revokeApiKey()">撤销</button>
                </div>
                <p style="color: #666; font-size: 12px; margin-top: 12px;">
                    创建时间：<%= user.api_key_created_at ? formatChinaTime(user.api_key_created_at, '%Y-%m-%d %H:%M') : '未知' %>
                </p>
            </div>
            <% } else { %>
            <button class="btn btn-primary" onclick="generateApiKey()">生成 API Key</button>
            <% } %>
        </div>
    </div>
    
    <div class="card">
        <h2 class="card-title">
            调用记录
            <span id="logsStats" style="font-size: 13px; font-weight: normal; color: #666; margin-left: 12px;"></span>
        </h2>
        
        <div class="logs-container" id="logsContainer">
            <div class="logs-wrapper" id="logsWrapper">
                <table class="logs-table" id="logsTable">
                    <thead>
                        <tr>
                            <th>时间</th>
                            <th>类型</th>
                            <th>视频链接</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody id="logsTableBody">
                        <!-- JS 动态填充 -->
                    </tbody>
                </table>
            </div>
        </div>
        
        <div id="logsPagination" class="pagination" style="display: none;">
            <div class="pagination-info">
                <span id="paginationInfo"></span>
            </div>
            <div class="pagination-controls">
                <button class="btn btn-secondary btn-sm" id="firstPageBtn" onclick="goToPage(1)">首页</button>
                <button class="btn btn-secondary btn-sm" id="prevPageBtn" onclick="goToPage(currentPage - 1)">上一页</button>
                <div class="page-numbers" id="pageNumbers"></div>
                <button class="btn btn-secondary btn-sm" id="nextPageBtn" onclick="goToPage(currentPage + 1)">下一页</button>
                <button class="btn btn-secondary btn-sm" id="lastPageBtn" onclick="goToPage(totalPages)">末页</button>
                <span style="margin-left: 12px;">跳转到</span>
                <input type="number" id="jumpPageInput" min="1" style="width: 60px; padding: 4px 8px; background: #1e1e2f; border: 1px solid #3a3a4a; border-radius: 4px; color: #fff; text-align: center;" onkeypress="if(event.key==='Enter') goToPage(parseInt(this.value))">
                <span>页</span>
            </div>
        </div>
        
        <p id="noLogsMessage" style="color: #666; text-align: center; padding: 20px; display: none;">暂无调用记录</p>
    </div>
</div>

<style>
    .logs-container {
        overflow-x: auto;
        overflow-y: auto;
        max-height: 400px;
        border-radius: 8px;
        scrollbar-width: thin;
        scrollbar-color: #3a3a4a #1e1e2f;
    }
    
    .logs-container::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    .logs-container::-webkit-scrollbar-track {
        background: #1e1e2f;
        border-radius: 4px;
    }
    
    .logs-container::-webkit-scrollbar-thumb {
        background: #3a3a4a;
        border-radius: 4px;
    }
    
    .logs-container::-webkit-scrollbar-thumb:hover {
        background: #4a4a5a;
    }
    
    .logs-container::-webkit-scrollbar-corner {
        background: #1e1e2f;
    }
    
    .video-url-cell {
        max-width: 400px;
        overflow-x: auto;
        white-space: nowrap;
        scrollbar-width: none; /* 默认隐藏 */
        -ms-overflow-style: none;
    }

    .video-url-cell::-webkit-scrollbar {
        height: 4px;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .video-url-cell:hover::-webkit-scrollbar-thumb,
    .video-url-cell:focus-within::-webkit-scrollbar-thumb {
        opacity: 1;
    }

    .video-url-cell::-webkit-scrollbar-thumb {
        background: #3a3a4a;
        border-radius: 2px;
    }
    
    .pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid #3a3a4a;
        flex-wrap: wrap;
        gap: 12px;
    }
    
    .pagination-info {
        color: #999;
        font-size: 13px;
    }
    
    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .page-numbers {
        display: flex;
        gap: 4px;
    }
    
    .page-numbers button {
        min-width: 36px;
    }
    
    .page-numbers button.active {
        background-color: #ff6768;
        border-color: #ff6768;
    }
    
    .page-ellipsis {
        color: #666;
        padding: 0 4px;
    }
</style>

<script>
    // 调用记录分页
    const allLogs = <%- JSON.stringify(logs || []) %>;
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let totalPages = 0;
    
    function formatLogTime(dateStr) {
        const d = new Date(dateStr);
        d.setHours(d.getHours() + 8);
        const month = String(d.getUTCMonth() + 1).padStart(2, '0');
        const day = String(d.getUTCDate()).padStart(2, '0');
        const hours = String(d.getUTCHours()).padStart(2, '0');
        const minutes = String(d.getUTCMinutes()).padStart(2, '0');
        return `${month}-${day} ${hours}:${minutes}`;
    }
    
    function initLogs() {
        const logsContainer = document.getElementById('logsContainer');
        const logsPagination = document.getElementById('logsPagination');
        const noLogsMessage = document.getElementById('noLogsMessage');
        const logsStats = document.getElementById('logsStats');
        
        if (allLogs.length === 0) {
            logsContainer.style.display = 'none';
            logsPagination.style.display = 'none';
            noLogsMessage.style.display = 'block';
            logsStats.textContent = '';
            return;
        }
        
        logsStats.textContent = `共 ${allLogs.length} 条记录`;
        totalPages = Math.ceil(allLogs.length / PAGE_SIZE);
        logsPagination.style.display = 'flex';
        noLogsMessage.style.display = 'none';
        
        renderLogs();
        updatePagination();
    }
    
    function renderLogs() {
        const tbody = document.getElementById('logsTableBody');
        tbody.innerHTML = '';
        
        const start = (currentPage - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;
        const pageLogs = allLogs.slice(start, end);
        
        pageLogs.forEach(log => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${formatLogTime(log.created_at)}</td>
                <td>${log.api_type}</td>
                <td class="video-url-cell" title="${log.video_url}">${log.video_url}</td>
                <td>
                    <span class="status-badge ${log.success ? 'status-success' : 'status-failed'}">
                        ${log.success ? '成功' : '失败'}
                    </span>
                </td>
            `;
            tbody.appendChild(tr);
        });
    }
    
    function updatePagination() {
        const paginationInfo = document.getElementById('paginationInfo');
        const pageNumbers = document.getElementById('pageNumbers');
        const firstPageBtn = document.getElementById('firstPageBtn');
        const prevPageBtn = document.getElementById('prevPageBtn');
        const nextPageBtn = document.getElementById('nextPageBtn');
        const lastPageBtn = document.getElementById('lastPageBtn');
        
        paginationInfo.textContent = `第 ${currentPage} / ${totalPages} 页，每页 ${PAGE_SIZE} 条`;
        
        firstPageBtn.disabled = currentPage === 1;
        prevPageBtn.disabled = currentPage === 1;
        nextPageBtn.disabled = currentPage === totalPages;
        lastPageBtn.disabled = currentPage === totalPages;
        
        // 生成页码按钮
        pageNumbers.innerHTML = '';
        const maxButtons = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxButtons / 2));
        let endPage = Math.min(totalPages, startPage + maxButtons - 1);
        
        if (endPage - startPage < maxButtons - 1) {
            startPage = Math.max(1, endPage - maxButtons + 1);
        }
        
        if (startPage > 1) {
            const btn = document.createElement('button');
            btn.className = 'btn btn-secondary btn-sm';
            btn.textContent = '1';
            btn.onclick = () => goToPage(1);
            pageNumbers.appendChild(btn);
            
            if (startPage > 2) {
                const ellipsis = document.createElement('span');
                ellipsis.className = 'page-ellipsis';
                ellipsis.textContent = '...';
                pageNumbers.appendChild(ellipsis);
            }
        }
        
        for (let i = startPage; i <= endPage; i++) {
            const btn = document.createElement('button');
            btn.className = `btn btn-secondary btn-sm${i === currentPage ? ' active' : ''}`;
            btn.textContent = i;
            btn.onclick = () => goToPage(i);
            pageNumbers.appendChild(btn);
        }
        
        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                const ellipsis = document.createElement('span');
                ellipsis.className = 'page-ellipsis';
                ellipsis.textContent = '...';
                pageNumbers.appendChild(ellipsis);
            }
            
            const btn = document.createElement('button');
            btn.className = 'btn btn-secondary btn-sm';
            btn.textContent = totalPages;
            btn.onclick = () => goToPage(totalPages);
            pageNumbers.appendChild(btn);
        }
    }
    
    function goToPage(page) {
        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;
        currentPage = page;
        renderLogs();
        updatePagination();
        
        // 滚动到表格顶部
        document.getElementById('logsContainer').scrollTop = 0;
    }
    
    // 初始化调用记录
    initLogs();
    
    // 密码显示/隐藏切换
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        const button = input.nextElementSibling;
        if (input.type === 'password') {
            input.type = 'text';
            button.textContent = '🙈';
        } else {
            input.type = 'password';
            button.textContent = '👁️';
        }
    }
    
    // 密码强度检测
    function checkPasswordStrength(password) {
        if (!password) return { level: 0, text: '请输入新密码' };
        
        let score = 0;
        if (password.length >= 6) score++;
        if (password.length >= 8) score++;
        if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
        if (/\d/.test(password)) score++;
        if (/[!@#$%^&*(),.?":{}|<>]/.test(password)) score++;
        
        if (score <= 2) return { level: 1, text: '弱 - 建议包含大小写字母、数字和特殊字符' };
        if (score <= 3) return { level: 2, text: '中等 - 可以更复杂一些' };
        return { level: 3, text: '强 - 密码强度良好' };
    }
    
    // 监听密码输入
    const newPasswordInput = document.getElementById('newPassword');
    const confirmPasswordInput = document.getElementById('confirmPassword');
    const strengthBar = document.getElementById('strengthBar');
    const strengthText = document.getElementById('strengthText');
    const matchText = document.getElementById('matchText');
    const submitBtn = document.getElementById('submitBtn');
    
    newPasswordInput.addEventListener('input', function() {
        // 有内容时显示强度横线
        const strengthContainer = strengthBar.parentElement;
        if (this.value) {
            strengthContainer.classList.add('visible');
        } else {
            strengthContainer.classList.remove('visible');
            strengthText.textContent = '请输入新密码';
        }

        const result = checkPasswordStrength(this.value);
        strengthBar.className = 'password-strength-bar';
        if (result.level === 1) strengthBar.classList.add('weak');
        else if (result.level === 2) strengthBar.classList.add('medium');
        else if (result.level === 3) strengthBar.classList.add('strong');
        strengthText.textContent = result.text;

        // 同时检查匹配
        if (confirmPasswordInput.value) {
            checkPasswordMatch();
        }
    });
    
    confirmPasswordInput.addEventListener('input', checkPasswordMatch);
    
    function checkPasswordMatch() {
        const newPwd = newPasswordInput.value;
        const confirmPwd = confirmPasswordInput.value;
        
        if (!confirmPwd) {
            matchText.textContent = '';
            matchText.className = 'password-match';
            submitBtn.disabled = true;
            return;
        }
        
        if (newPwd === confirmPwd) {
            matchText.textContent = '✓ 两次输入的密码一致';
            matchText.className = 'password-match match';
            submitBtn.disabled = false;
        } else {
            matchText.textContent = '✗ 两次输入的密码不一致';
            matchText.className = 'password-match mismatch';
            submitBtn.disabled = true;
        }
    }
    
    // 修改密码
    document.getElementById('passwordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        const newPwd = formData.get('new_password');
        const confirmPwd = formData.get('confirm_password');
        
        if (newPwd !== confirmPwd) {
            alert('两次输入的密码不一致');
            return;
        }
        
        try {
            const response = await fetch('/profile/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    old_password: formData.get('old_password'),
                    new_password: formData.get('new_password')
                })
            });
            
            const result = await response.json();
            
            if (result.success) {
                alert('密码修改成功');
                e.target.reset();
                strengthBar.className = 'password-strength-bar';
                strengthBar.parentElement.classList.remove('visible');
                strengthText.textContent = '请输入新密码';
                matchText.textContent = '';
                submitBtn.disabled = true;
            } else {
                alert(result.message || '修改失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    });
    
    // 生成 API Key
    async function generateApiKey() {
        try {
            const response = await fetch('/profile/api-key/generate', { method: 'POST' });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert(result.message || '生成失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    }
    
    // 复制 API Key
    function copyApiKey() {
        const apiKey = document.getElementById('apiKeyRevealed').textContent;
        navigator.clipboard.writeText(apiKey).then(() => {
            alert('API Key 已复制到剪贴板');
        });
    }
    
    // 撤销 API Key
    async function revokeApiKey() {
        if (!confirm('确定要撤销当前的 API Key 吗？撤销后无法恢复。')) return;
        
        try {
            const response = await fetch('/profile/api-key/revoke', { method: 'POST' });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert(result.message || '撤销失败');
            }
        } catch (error) {
            alert('请求失败');
        }
    }
    
    // API Key 显示/隐藏切换
    let isApiKeyVisible = false;
    function toggleApiKeyVisibility() {
        const hiddenSpan = document.getElementById('apiKeyHidden');
        const revealedSpan = document.getElementById('apiKeyRevealed');
        const toggleBtn = document.getElementById('toggleBtn');
        
        if (isApiKeyVisible) {
            hiddenSpan.style.display = 'inline';
            revealedSpan.style.display = 'none';
            toggleBtn.textContent = '显示';
            isApiKeyVisible = false;
        } else {
            hiddenSpan.style.display = 'none';
            revealedSpan.style.display = 'inline';
            toggleBtn.textContent = '隐藏';
            isApiKeyVisible = true;
        }
    }
</script>

</body>
</html>
